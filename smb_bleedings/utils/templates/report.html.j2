<html lang="{{ lang }}" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SMBleedings — {{ L.report_title_default }}{% if summary.title %} — {{ summary.title }}{% endif %}</title>
<style>
