{% macro who_block(f, L) -%}
{%- set legit_prefixes = ['SYSTEM', 'NT AUTHORITY\\SYSTEM', 'BUILTIN\\ADMINISTRATORS', 'CREATOR OWNER'] -%}
{%- set danger_names = f.dangerous_entries | map(attribute='account') | list -%}
{%- set seen = namespace(s=[]) -%}
{%- set uniq_acl = [] -%}
{%- for a in (f.acl_entries or f.dangerous_entries) -%}
  {%- set key = a.account ~ '|' ~ a.access_right ~ '|' ~ a.ace_type -%}
  {%- if key not in seen.s -%}
    {%- set _ = seen.s.append(key) -%}
    {%- set _ = uniq_acl.append(a) -%}
  {%- endif -%}
{%- endfor -%}
{%- set ns_g = namespace(danger=[], legit=[], other=[]) -%}
{%- for a in uniq_acl -%}
  {%- set acct_up = a.account.upper() -%}
  {%- set is_legit = (acct_up in legit_prefixes) or ('BUILTIN\\ADMINISTRATORS' in acct_up) -%}
  {%- if a.account in danger_names -%}
    {%- set _ = ns_g.danger.append(a) -%}
  {%- elif is_legit -%}
    {%- set _ = ns_g.legit.append(a) -%}
  {%- else -%}
    {%- set _ = ns_g.other.append(a) -%}
  {%- endif -%}
{%- endfor -%}
{%- if uniq_acl -%}
<div class="who-section">
  <div class="who-title">{{ L.who_access }}<span class="who-count">{{ uniq_acl | length }} {{ L.accounts_count }}</span></div>
  {%- for grp_cls, grp_lbl, grp_arr in [('g-danger', L.who_danger, ns_g.danger), ('', L.who_other, ns_g.other), ('g-legit', L.who_legit, ns_g.legit)] -%}
    {%- if grp_arr -%}
    <div class="who-group {{ grp_cls }}">
      <div class="who-group-label"><span class="dot"></span>{{ grp_lbl }} <span style="opacity:0.6">({{ grp_arr | length }})</span></div>
      {%- for a in grp_arr -%}
        {%- set rlow = a.access_right | lower -%}
        {%- set rcls = 'r-full' if 'full' in rlow else ('r-change' if ('change' in rlow or 'write' in rlow) else 'r-read') -%}
        <div class="who-row"><span class="who-acct">{{ a.account }}</span><span class="who-right {{ rcls }}">{{ a.access_right }}</span>{% if a.ace_type | lower == 'deny' %}<span class="who-type t-deny">DENY</span>{% endif %}</div>
      {%- endfor -%}
    </div>
    {%- endif -%}
  {%- endfor -%}
</div>
{%- endif -%}
{%- endmacro %}
{% macro finding_detail(f, L) -%}
{% if f.reasons %}
<div class="hf-why-section">
  <div class="hf-section-title hf-why-title">{{ L.why_risky }}</div>
  <div class="why-items">
  {% for r in f.reasons %}
    {% set matched = r | regex_replace('^\\[([^\\]]+)\\].*$', '\\1') %}
    {% set tag = matched if matched != r else '' %}
    {% set text = r | regex_replace('^\\[[^\\]]+\\]\\s*', '') %}
    <div class="why-item">
      <div class="why-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
      <div class="why-text">{% if tag %}<span class="why-tag">{{ tag }}</span>{% endif %}{{ text }}</div>
    </div>
  {% endfor %}
  </div>
</div>
{% endif %}
{% if f.impacts or f.share.tested_permissions %}
<div class="hf-impact-section">
  <div class="hf-section-title hf-impact-title">{{ L.concrete_impact }}</div>
  {% set legit_prefixes = ['SYSTEM', 'NT AUTHORITY\\SYSTEM', 'BUILTIN\\ADMINISTRATORS', 'CREATOR OWNER'] %}
  {% set perm_map = {'LIST': ['Full', 'Change', 'Read'], 'READ': ['Full', 'Change', 'Read'], 'WRITE': ['Full', 'Change'], 'DELETE': ['Full', 'Change'], 'EXECUTE': ['Full'], 'SPECIAL': ['Full']} %}
  {% set perm_texts = {'LIST': L.perm_list, 'READ': L.perm_read, 'WRITE': L.perm_write, 'DELETE': L.perm_delete, 'EXECUTE': L.perm_execute, 'SPECIAL': L.perm_special} %}
  {% for p in f.share.tested_permissions %}
    {% if p in perm_texts %}
    {% set ns_actors = namespace(danger=[], legit=[]) %}
    {% for ace in f.acl_entries if ace.ace_type != 'Deny' %}
      {% if ace.access_right in perm_map.get(p, []) %}
        {% set is_legit = ace.account.upper() in legit_prefixes | map('upper') | list %}
        {% if is_legit %}{% set ns_actors.legit = ns_actors.legit + [ace.account] %}{% else %}{% set ns_actors.danger = ns_actors.danger + [ace.account] %}{% endif %}
      {% endif %}
    {% endfor %}
    <div class="hf-impact-block">
      <div class="hf-impact-text">{{ perm_texts[p] }}</div>
      {% if ns_actors.danger or ns_actors.legit %}
      <div class="impact-actors">
        {% if ns_actors.danger %}
        <div class="actor-row actor-row-danger" title="{{ L.accessible_to }}">
          <span class="actor-icon" aria-label="{{ L.accessible_to }}">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </span>
          <span class="actor-chips">{% for a in ns_actors.danger | unique %}<span class="chip chip-danger">{{ a }}</span>{% endfor %}</span>
        </div>
        {% endif %}
        {% if ns_actors.legit %}
        <div class="actor-row actor-row-legit" title="{{ L.legit_access }}">
          <span class="actor-icon" aria-label="{{ L.legit_access }}">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="actor-chips">{% for a in ns_actors.legit | unique %}<span class="chip chip-legit">{{ a }}</span>{% endfor %}<span class="legit-tag">{{ L.legitimate }}</span></span>
        </div>
        {% endif %}
      </div>
      {% endif %}
    </div>
    {% endif %}
  {% endfor %}
  {% if f.impacts %}
  <div class="hf-impact-other">
    <div class="hf-impact-other-label">{{ L.other_impacts }}</div>
    {% for imp in f.impacts %}<div class="hf-impact-other-line">{{ imp | regex_replace('^\\[[^\\]]+\\]\\s*', '') }}</div>{% endfor %}
  </div>
  {% endif %}
</div>
{% endif %}
{% if f.recommendations %}
<div class="hf-suggest-section">
  <div class="hf-suggest-title">{{ L.remediation }}{% if f.risk_level == 'CRITICAL' %} <span class="urgency-badge urgency-critical">IMMEDIATE</span>{% elif f.risk_level == 'HIGH' %} <span class="urgency-badge urgency-high">&lt; 1 week</span>{% elif f.risk_level == 'MEDIUM' %} <span class="urgency-badge urgency-medium">Next change window</span>{% endif %}</div>
  {% for r in f.recommendations %}
    {% set cmd_marker = 'Command:' if 'Command:' in r else ('Commande :' if 'Commande :' in r else '') %}
    {% if cmd_marker %}
      {% set idx = r.index(cmd_marker) %}
      <div class="hf-suggest-text">{{ r[:idx] | trim | regex_replace('\\.$', '') }}</div>
      <div class="hf-suggest-cmd" onclick="copyCmd(this)" title="{{ L.command }}">{{ r[idx + cmd_marker | length:] | trim | regex_replace('\\.$', '') }}</div>
    {% else %}
      <div class="hf-suggest-text">{{ r }}</div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}
{% if f.content_matches %}
<div class="hf-suggest-section" style="border-left:3px solid #dc2626">
  <div class="hf-suggest-title">🩸 Sensitive content ({{ f.content_matches | length }})</div>
  {% for m in f.content_matches %}
    <div class="hf-suggest-text" style="font-family:monospace;font-size:.78rem">
      {{ m.file_path }}{% if m.file_size %} <span style="opacity:.6">({{ m.file_size }} B)</span>{% endif %}
      {% if m.matched_keywords %} — <span style="color:#fca5a5">{{ m.matched_keywords | join(', ') }}</span>{% endif %}
    </div>
  {% endfor %}
</div>
{% endif %}
{%- endmacro %}
