# ShareMyBleedings — Credentials & configuration
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# --- Credentials SMB ---
SMB_USERNAME=DOMAINE\utilisateur
SMB_PASSWORD=motdepasse
SMB_DOMAIN=DOMAINE

# --- Plages IP à scanner ---
SMB_RANGES=192.168.1.0/24,10.0.0.0/24

# --- Options de scan ---
SMB_THREADS=50
SMB_TIMEOUT=3.0
# SMB_EXCLUDE_SYSTEM=true
# SMB_LANG=en
# SMB_TITLE=Audit Q1 2026

# --- Domain Controller (LDAP SID resolution) ---
# SMB_DC=dc01.domaine.local

# --- Sortie ---
SMB_OUTPUT_FORMAT=json
SMB_OPEN_BROWSER=true

# --- Content scan (manspider) ---
# SMB_SCAN_CONTENT=false
# SMB_CONTENT_KEYWORDS=password,secret,iban
# SMB_CONTENT_LOOT_DIR=./loot
# SMB_CONTENT_MAX_FILESIZE=10M
# SMB_CONTENT_KEEP_LOOT=true
